{
  "name": "@webrek/mx-cp",
  "version": "0.2.0",
  "description": "Códigos postales de México (SEPOMEX) → estado, municipio (CVEGEO de INEGI) y colonias. Carga por prefijo bajo demanda, sin API key.",
  "keywords": [
    "mexico",
    "codigo-postal",
    "codigos-postales",
    "sepomex",
    "cp",
    "zip-code",
    "inegi",
    "colonias",
    "asentamientos"
  ],
  "license": "MIT",
  "author": "webrek",
  "repository": {
    "type": "git",
    "url": "https://github.com/webrek/mx-cp.git"
  },
  "type": "module",
  "sideEffects": false,
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build:data": "node scripts/build-cp.mjs",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm format:check && pnpm typecheck && pnpm test && pnpm build",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
